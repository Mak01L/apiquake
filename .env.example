# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/apiquake

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Email (Resend) ---
# Get a key at https://resend.com. Optional: the app falls back to
# logging emails to stdout if RESEND_API_KEY is empty.
RESEND_API_KEY=
EMAIL_FROM=apiquake <notify@apiquake.dev>

# --- LLM (Anthropic Claude Haiku) ---
# Optional: if empty the classifier will fall back to a heuristic and
# tag all diffs as INFO.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Stripe (billing) ---
# Optional for development. Leave empty to run in dev with stub billing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# --- GitHub (for github_releases sources) ---
# Strongly recommended. Unauth'd GitHub API is 60 req/hour per IP which is
# not enough for 10+ github_releases sources. A fine-grained PAT with NO
# scopes (public read-only) gives you 5,000 req/hour.
# Get one at https://github.com/settings/personal-access-tokens/new
# (set "Public Repositories (read-only)" → no scopes needed, just create it).
GITHUB_TOKEN=

# --- Worker toggles ---
WORKER_CONCURRENCY=2
# How often to schedule a global refresh of all API sources (cron).
# Defaults to every 30 minutes. BullMQ pattern syntax.
CRON_REFRESH_PATTERN=*/30 * * * *
