# syntax=docker/dockerfile:1.7
FROM node:22-alpine
WORKDIR /app
RUN corepack enable
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile 2>/dev/null || pnpm install
COPY . .
ENV NODE_ENV=production
# Run migrations on boot, then the worker. Safe: migrate is idempotent.
CMD ["sh", "-c", "pnpm db:migrate && pnpm db:seed && pnpm worker"]
